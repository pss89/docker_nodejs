# 1. 의존성 폴더 (용량이 매우 크므로 절대 Git에 올리지 않음)
node_modules/
backend/node_modules/
frontend/node_modules/

# 2. 환경 변수 및 비밀 키 (보안상 가장 중요!)
.env
.env.local
.env.*.local

# 3. 프론트엔드 빌드 결과물 (코드가 변경되면 언제든 새로 생성 가능함)
dist/
build/
frontend/dist/

# 4. 로그 파일 (실행 과정에서 생기는 찌꺼기 파일들)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# 5. OS 생성 파일 (Mac 사용자 필수 추가 항목)
.DS_Store
.AppleDouble
.LSOverride
Icon

# 6. 에디터 및 IDE 설정 (VSCode 등 개인 설정 공유 방지)
.vscode/
.idea/
*.swp
*.swo